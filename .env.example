NO_PROXY=localhost,127.0.0.1,0.0.0.0,::1
# ── Testing / mock mode ────────────────────────────────────────────────────────
# Set MOCK_JENKINS=true to run the Jenkins workflow without a real Jenkins server.
# Tools read from tests/mock_data/jenkins/. Supports build 142 (compilation error),
# build 143 (JUnit test failure), and pipeline build 1 (ms-build SUCCESS scenario).
#MOCK_JENKINS=false

# Set MOCK_CONFLUENCE=true to run fetch_page_by_id and fetch_confluence_page without
# a real Confluence server. Tools read from tests/mock_data/confluence/.
# find_confluence_page_ids still uses Chroma — ingest mock data first (see README).
#MOCK_CONFLUENCE=false

# Directory containing mock_data/jenkins/ and mock_data/confluence/ subdirectories.
# Relative to project root, or absolute.
#MOCK_DATA_DIR=tests/mock_data

# ── Token limits ───────────────────────────────────────────────────────────────
# Hard ceiling on output tokens for every agent — no per-agent value can exceed this.
# Lower this to cap worst-case spend. Default: 4096.
MAX_TOKENS_HARD_LIMIT=4096

# ── Logging ────────────────────────────────────────────────────────────────────
# LOG_LEVEL controls which messages are written to LOG_FILE.
#   OFF     — no logging (default)
#   ERROR   — errors only
#   WARNING — warnings + errors
#   INFO    — routing decisions, workflow progress, final responses
#   DEBUG   — everything (agent steps, LLM inputs/outputs, all of the above)
LOG_LEVEL=OFF
#LOG_FILE=app.log   # default: app.log in the project root

# ── Inline agent step visibility ───────────────────────────────────────────────
# Shows collapsible tool-call blocks inside the chat window (like ChatGPT's
# "Used tool: search" indicator).  Combines with TaskList for a two-level view:
#   off     — TaskList only; cleanest for end users (default)
#   tools   — show each tool call by name; no input/output detail
#   verbose — show tool name + truncated input/output; useful for debugging
AGENT_STEPS=off

# ── Default models ─────────────────────────────────────────────────────────────
# Must match a model `id` defined in llm_config.yaml.
DEFAULT_MODEL=gpt-4o-mini
DEFAULT_ROUTING_MODEL=gpt-4o-mini

# ── Checkpointer ───────────────────────────────────────────────────────────────
# "dev" uses in-process MemorySaver (no setup needed)
# "prod" uses AsyncPostgresSaver (requires POSTGRES_URL and langgraph-checkpoint-postgres)
APP_ENV=dev
#POSTGRES_URL=postgresql://user:pass@host:5432/dbname

# ── API keys and endpoints ─────────────────────────────────────────────────────
# Add keys only for the providers you use.
# The variable names here must match api_key_env / base_url_env in llm_config.yaml.

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
#ANTHROPIC_BASE_URL=       # custom endpoint (Azure AI Foundry, Bedrock proxy, etc.)

# OpenAI / OpenAI-compatible (Groq, Together, Ollama, vLLM …)
#OPENAI_API_KEY=sk-...
#OPENAI_BASE_URL=          # e.g. https://api.groq.com/openai/v1

# Azure OpenAI
#AZURE_OPENAI_API_KEY=
#AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
#AZURE_OPENAI_API_VERSION=2024-02-01

# Google Gemini
#GOOGLE_API_KEY=
#GOOGLE_BASE_URL=          # custom endpoint (Vertex AI, etc.)

# ── History compaction ─────────────────────────────────────────────────────────
# Strategy for trimming conversation history as it grows:
#   none    — no trimming, history grows unbounded (default — safe starting point)
#   window  — keep only the last N messages (zero extra cost)
#   summary — condense older messages into a summary via an LLM call when the
#             history exceeds HISTORY_WINDOW_SIZE messages
#HISTORY_STRATEGY=none
#HISTORY_WINDOW_SIZE=20
#HISTORY_SUMMARY_MODEL=         # defaults to DEFAULT_ROUTING_MODEL if unset

# ── Tool integrations ──────────────────────────────────────────────────────────
JENKINS_URL=http://localhost:8080
JENKINS_USER=admin
JENKINS_TOKEN=your-jenkins-api-token

# ── Jira Data Center ───────────────────────────────────────────────────────────
# Used by: devops_pipeline workflow, Jira MCP server (mcp/jira/server.py)
#
# Authentication — use ONE of the two methods below:
#
# Method 1 (recommended): Personal Access Token
#   Create under: Profile → Personal Access Tokens
#   Available in Jira Data Center 8.14+
JIRA_URL=https://jira.your-company.com
JIRA_TOKEN=your-jira-personal-access-token
#
# Method 2 (fallback): Basic Auth — only if PAT is unavailable
#JIRA_USER=your-jira-username
#JIRA_PASSWORD=your-jira-password

# ── MCP Server ports (optional — defaults shown) ───────────────────────────────
# Override these if the default ports conflict with other services.
#JENKINS_SSE_HOST=0.0.0.0
#JENKINS_SSE_PORT=8001
#JIRA_SSE_HOST=0.0.0.0
#JIRA_SSE_PORT=8002

# ── Mock mode for Jira ─────────────────────────────────────────────────────────
# Set MOCK_JIRA=true to run the DevOps pipeline without a real Jira server.
# Tools read from tests/mock_data/jira/. Issue key will be MYPROJ-123.
#MOCK_JIRA=false

# ── Confluence Q&A RAG ─────────────────────────────────────────────────────────
# Required only for the confluence_qa workflow (Confluence Data Center edition).
# CONFLUENCE_TOKEN: Personal Access Token — create in Confluence under
#   Profile → Personal Access Tokens
#CONFLUENCE_URL=https://confluence.your-company.com
#CONFLUENCE_TOKEN=your-personal-access-token

# Vector store path and collection (created by scripts/ingest_confluence.py)
#CHROMA_PATH=data/chroma
#CHROMA_COLLECTION=confluence

# Embedding provider: "local" (loads from models/<model_name>/ directory) or "openai"
# "local" requires: pip install langchain-huggingface sentence-transformers
# "openai" requires OPENAI_API_KEY and pip install langchain-openai
#EMBEDDING_PROVIDER=local
#
# EMBEDDING_MODEL is optional — leave unset to use the provider default:
#   local  → all-MiniLM-L6-v2   (must match the folder name under models/)
#   openai → text-embedding-3-small
#EMBEDDING_MODEL=

# If your embeddings are served by an OpenAI-compatible endpoint (e.g. a company
# gateway, Ollama, vLLM) set these explicitly.  This avoids conflicts with the
# LLM provider's OPENAI_API_KEY / OPENAI_BASE_URL which may point elsewhere.
#EMBEDDING_BASE_URL=https://your-embedding-endpoint/v1
#EMBEDDING_API_KEY=your-embedding-api-key

# ── Offline / air-gapped mode (HuggingFace) ────────────────────────────────────
# Set these to 1 to prevent sentence-transformers and HuggingFace Datasets from
# attempting any outbound network calls. Required in air-gapped environments.
# The application also sets these automatically when EMBEDDING_PROVIDER=local,
# but declaring them here ensures all HF libraries respect the setting from startup.
HF_DATASETS_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# ── RAG improvements — Chunking strategy ──────────────────────────────────────
# CHUNKING_STRATEGY controls how Confluence pages are split during ingestion:
#   html    — BeautifulSoup heading-based sections (default, no extra dependencies)
#   docling — docling HybridChunker: context-aware, tables/code as atomic units,
#             heading breadcrumbs in every chunk; requires: pip install docling>=2.0.0
#CHUNKING_STRATEGY=html
#
# DOCLING_TOKENIZER_PROVIDER selects how HybridChunker counts tokens:
#   local             — load from DOCLING_TOKENIZER_MODEL path (default; air-gapped safe)
#   openai_compatible — use tiktoken (bundled with langchain-openai); chunk sizes are
#                       measured in the same token units as OpenAI embedding/LLM models;
#                       no local model files required
#DOCLING_TOKENIZER_PROVIDER=local
#
# When DOCLING_TOKENIZER_PROVIDER=local in an air-gapped environment, point to a
# local tokenizer model directory (e.g. downloaded via huggingface-cli download):
#DOCLING_TOKENIZER_MODEL=models/all-MiniLM-L6-v2
#
# When DOCLING_TOKENIZER_PROVIDER=openai_compatible, EMBEDDING_MODEL is used to
# select the matching tiktoken encoding (e.g. text-embedding-3-small → cl100k_base).
# Leave EMBEDDING_MODEL unset to default to text-embedding-3-small.

# ── RAG improvements — BM25 hybrid retrieval ──────────────────────────────────
# ENABLE_BM25=true adds BM25 keyword search alongside vector similarity search.
# Results from both are merged using Reciprocal Rank Fusion (RRF) before ranking.
# Requires: pip install rank-bm25
# After enabling, re-run scripts/ingest_confluence.py to build the BM25 index.
#ENABLE_BM25=false
#BM25_INDEX_PATH=data/bm25.pkl
#RRF_K=60    # RRF smoothing constant (paper default: 60; lower = rank position matters more)

# ── RAG improvements — Reranker ───────────────────────────────────────────────
# RERANKER_PROVIDER selects which reranker to use after retrieval:
#   none              — no reranking; use RRF/vector order as-is (default)
#   openai_compatible — cross-encoder via OpenAI-compatible /v1/rerank endpoint
#                       compatible with: mxbai-rerank-large-v1, Jina Reranker, etc.
#                       requires: pip install httpx (already in requirements.txt)
#   local             — sentence-transformers CrossEncoder (fully air-gapped safe)
#                       requires: pip install sentence-transformers
#
#RERANKER_PROVIDER=none
#
# OpenAI-compatible reranker (RERANKER_PROVIDER=openai_compatible):
#RERANKER_BASE_URL=https://your-gateway.internal    # e.g. vLLM or Infinity serving mxbai
#RERANKER_API_KEY=your-reranker-api-key             # omit if no auth required
#RERANKER_MODEL=mxbai-rerank-large-v1               # model name sent in the request body
#
# Local reranker (RERANKER_PROVIDER=local):
#RERANKER_LOCAL_MODEL=models/mxbai-rerank-large-v1  # local path or HuggingFace model id
#
# Shared reranker settings:
#RERANKER_CANDIDATE_K=30   # pages collected before reranking (more = better recall, slower)
#RERANKER_TOP_N=5          # pages returned after reranking
