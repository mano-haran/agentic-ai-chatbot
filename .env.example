# ── Token limits ───────────────────────────────────────────────────────────────
# Hard ceiling on output tokens for every agent — no per-agent value can exceed this.
# Lower this to cap worst-case spend. Default: 4096.
MAX_TOKENS_HARD_LIMIT=4096

# ── Default models ─────────────────────────────────────────────────────────────
# Must match a model `id` defined in llm_config.yaml.
DEFAULT_MODEL=claude-sonnet-4-6
DEFAULT_ROUTING_MODEL=claude-haiku-4-5-20251001

# ── Checkpointer ───────────────────────────────────────────────────────────────
# "dev" uses in-process MemorySaver (no setup needed)
# "prod" uses AsyncPostgresSaver (requires POSTGRES_URL and langgraph-checkpoint-postgres)
APP_ENV=dev
#POSTGRES_URL=postgresql://user:pass@host:5432/dbname

# ── API keys and endpoints ─────────────────────────────────────────────────────
# Add keys only for the providers you use.
# The variable names here must match api_key_env / base_url_env in llm_config.yaml.

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
#ANTHROPIC_BASE_URL=       # custom endpoint (Azure AI Foundry, Bedrock proxy, etc.)

# OpenAI / OpenAI-compatible (Groq, Together, Ollama, vLLM …)
#OPENAI_API_KEY=sk-...
#OPENAI_BASE_URL=          # e.g. https://api.groq.com/openai/v1

# Azure OpenAI
#AZURE_OPENAI_API_KEY=
#AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
#AZURE_OPENAI_API_VERSION=2024-02-01

# Google Gemini
#GOOGLE_API_KEY=
#GOOGLE_BASE_URL=          # custom endpoint (Vertex AI, etc.)

# ── Tool integrations ──────────────────────────────────────────────────────────
JENKINS_URL=http://localhost:8080
JENKINS_USER=admin
JENKINS_TOKEN=your-jenkins-api-token
