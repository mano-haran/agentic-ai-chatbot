# ── Token limits ───────────────────────────────────────────────────────────────
# Hard ceiling on output tokens for every agent — no per-agent value can exceed this.
# Lower this to cap worst-case spend. Default: 4096.
MAX_TOKENS_HARD_LIMIT=4096

# ── Logging ────────────────────────────────────────────────────────────────────
# LOG_LEVEL controls which messages are written to LOG_FILE.
#   OFF     — no logging (default)
#   ERROR   — errors only
#   WARNING — warnings + errors
#   INFO    — routing decisions, workflow progress, final responses
#   DEBUG   — everything (agent steps, LLM inputs/outputs, all of the above)
LOG_LEVEL=OFF
#LOG_FILE=app.log   # default: app.log in the project root

# ── Inline agent step visibility ───────────────────────────────────────────────
# Shows collapsible tool-call blocks inside the chat window (like ChatGPT's
# "Used tool: search" indicator).  Combines with TaskList for a two-level view:
#   off     — TaskList only; cleanest for end users (default)
#   tools   — show each tool call by name; no input/output detail
#   verbose — show tool name + truncated input/output; useful for debugging
AGENT_STEPS=off

# ── Default models ─────────────────────────────────────────────────────────────
# Must match a model `id` defined in llm_config.yaml.
DEFAULT_MODEL=gpt-4o-mini
DEFAULT_ROUTING_MODEL=gpt-4o-mini

# ── Checkpointer ───────────────────────────────────────────────────────────────
# "dev" uses in-process MemorySaver (no setup needed)
# "prod" uses AsyncPostgresSaver (requires POSTGRES_URL and langgraph-checkpoint-postgres)
APP_ENV=dev
#POSTGRES_URL=postgresql://user:pass@host:5432/dbname

# ── API keys and endpoints ─────────────────────────────────────────────────────
# Add keys only for the providers you use.
# The variable names here must match api_key_env / base_url_env in llm_config.yaml.

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
#ANTHROPIC_BASE_URL=       # custom endpoint (Azure AI Foundry, Bedrock proxy, etc.)

# OpenAI / OpenAI-compatible (Groq, Together, Ollama, vLLM …)
#OPENAI_API_KEY=sk-...
#OPENAI_BASE_URL=          # e.g. https://api.groq.com/openai/v1

# Azure OpenAI
#AZURE_OPENAI_API_KEY=
#AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
#AZURE_OPENAI_API_VERSION=2024-02-01

# Google Gemini
#GOOGLE_API_KEY=
#GOOGLE_BASE_URL=          # custom endpoint (Vertex AI, etc.)

# ── History compaction ─────────────────────────────────────────────────────────
# Strategy for trimming conversation history as it grows:
#   none    — no trimming, history grows unbounded (default — safe starting point)
#   window  — keep only the last N messages (zero extra cost)
#   summary — condense older messages into a summary via an LLM call when the
#             history exceeds HISTORY_WINDOW_SIZE messages
#HISTORY_STRATEGY=none
#HISTORY_WINDOW_SIZE=20
#HISTORY_SUMMARY_MODEL=         # defaults to DEFAULT_ROUTING_MODEL if unset

# ── Tool integrations ──────────────────────────────────────────────────────────
JENKINS_URL=http://localhost:8080
JENKINS_USER=admin
JENKINS_TOKEN=your-jenkins-api-token

# ── Confluence Q&A RAG ─────────────────────────────────────────────────────────
# Required only for the confluence_qa workflow (Confluence Data Center edition).
# CONFLUENCE_TOKEN: Personal Access Token — create in Confluence under
#   Profile → Personal Access Tokens
#CONFLUENCE_URL=https://confluence.your-company.com
#CONFLUENCE_TOKEN=your-personal-access-token

# Vector store path and collection (created by scripts/ingest_confluence.py)
#CHROMA_PATH=data/chroma
#CHROMA_COLLECTION=confluence

# Embedding provider: "local" (loads from models/<model_name>/ directory) or "openai"
# "local" requires: pip install langchain-huggingface sentence-transformers
# "openai" requires OPENAI_API_KEY and pip install langchain-openai
#EMBEDDING_PROVIDER=local
#
# EMBEDDING_MODEL is optional — leave unset to use the provider default:
#   local  → all-MiniLM-L6-v2   (must match the folder name under models/)
#   openai → text-embedding-3-small
#EMBEDDING_MODEL=

# ── Offline / air-gapped mode (HuggingFace) ────────────────────────────────────
# Set these to 1 to prevent sentence-transformers and HuggingFace Datasets from
# attempting any outbound network calls. Required in air-gapped environments.
# The application also sets these automatically when EMBEDDING_PROVIDER=local,
# but declaring them here ensures all HF libraries respect the setting from startup.
HF_DATASETS_OFFLINE=1
TRANSFORMERS_OFFLINE=1
